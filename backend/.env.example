# Copy to .env and fill in. NEVER commit the real .env.
# The Gemini API key lives ONLY here on the server — never in the Flutter binary.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Optional overrides
PORT=8787
# Free-tier-friendly model. gemini-2.5-flash or gemini-2.0-flash.
GEMINI_MODEL=gemini-2.5-flash
